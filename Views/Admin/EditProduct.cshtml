@model PTDA_Demo.Models.EditProductViewModel
@{
    ViewBag.Title = "EditProduct";
    Layout = "~/Views/Shared/_GreenMart_Dashboard_layout.cshtml";
}

<div class="max-w-5xl mx-auto px-4 py-8">
    <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">

        <div class="bg-surface-container-high px-6 py-5 border-b border-gray-200 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-[28px]">edit_square</span>
                <h2 class="text-xl font-bold text-gray-800">Chỉnh sửa sản phẩm</h2>
            </div>
            <span class="bg-white px-3 py-1 rounded-full text-sm font-semibold text-gray-500 border border-gray-200">
                ID: #@Model.ProductID
            </span>
        </div>

        <div class="p-6 sm:p-8">
            @using (Html.BeginForm("EditProduct", "Admin", FormMethod.Post, new { enctype = "multipart/form-data", @class = "space-y-6" }))
            {
                @Html.AntiForgeryToken()

                @Html.HiddenFor(m => m.ProductID)
                @Html.HiddenFor(m => m.ExistingImageURL)

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <div class="lg:col-span-2 space-y-6">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Tên sản phẩm <span class="text-red-500">*</span></label>
                            @Html.TextBoxFor(m => m.ProductName, new { @class = "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none" })
                            @Html.ValidationMessageFor(m => m.ProductName, "", new { @class = "text-red-500 text-xs italic mt-1 block" })
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1">Danh mục <span class="text-red-500">*</span></label>
                                @Html.DropDownListFor(m => m.CategoryID, (SelectList)ViewBag.CategoryList, new { @class = "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none bg-white" })
                                @Html.ValidationMessageFor(m => m.CategoryID, "", new { @class = "text-red-500 text-xs italic mt-1 block" })
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1">Giá bán (VNĐ) <span class="text-red-500">*</span></label>
                                @Html.TextBoxFor(m => m.Price, new { type = "number", min = "0", @class = "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none" })
                                @Html.ValidationMessageFor(m => m.Price, "", new { @class = "text-red-500 text-xs italic mt-1 block" })
                            </div>
                        </div>
                        
                        <div class="w-1/2 pr-3">
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Tồn kho <span class="text-red-500">*</span></label>
                            @*
        @Html.TextBoxFor(m => m.StockQuantity, new { type = "number", min = "0", @class = "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none" })
        @Html.ValidationMessageFor(m => m.StockQuantity, "", new { @class = "text-red-500 text-xs italic mt-1 block" })
                            *@
                            @Html.DisplayFor(m => m.StockQuantity, new { type = "number", min = "0", @class = "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none" })

                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Mô tả chi tiết</label>
                            @Html.TextAreaFor(m => m.Description, new { @class = "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none", rows = "5" })
                        </div>
                    </div>

                    <div class="space-y-6">
                        <div class="bg-gray-50 p-5 rounded-lg border border-gray-200">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Hình ảnh sản phẩm</label>

                            <div class="mb-4 flex justify-center bg-white border border-gray-200 rounded-lg p-2">
                                @{
                                    string imgSrc = string.IsNullOrEmpty(Model.ExistingImageURL)
                                                    ? "https://placehold.co/200x200?text=No+Image"
                                                    : Url.Content("~/Content/Images/Products/" + Model.ExistingImageURL);
                                }
                                <img id="img-preview" src="@imgSrc" alt="Product Preview" class="w-40 h-40 object-cover rounded shadow-sm" />
                            </div>

                            <input type="file" name="ImageUpload" id="ImageUpload" accept=".jpg, .jpeg, .png" class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-primary-container file:text-primary hover:file:bg-primary/20 cursor-pointer" />
                            <p class="text-xs text-gray-500 mt-2">Chọn ảnh mới nếu muốn thay đổi (JPG, PNG. Tối đa 5MB).</p>
                            @Html.ValidationMessageFor(m => m.ImageUpload, "", new { @class = "text-red-500 text-xs italic mt-1 block" })
                        </div>

                        @*<div class="bg-gray-50 p-5 rounded-lg border border-gray-200">
            <label class="block text-sm font-semibold text-gray-700 mb-3">Trạng thái kinh doanh</label>
            <div class="flex items-center">
                @Html.CheckBoxFor(m => m.IsActive, new { @class = "w-5 h-5 text-primary border-gray-300 rounded focus:ring-primary cursor-pointer" })
                <label for="IsActive" class="ml-2 font-medium text-gray-700 cursor-pointer">Đang bán trên Store</label>
            </div>
        </div>*@
                    </div>
                </div>

                <div class="flex items-center justify-end gap-4 pt-6 border-t border-gray-100 mt-8">
                    <a href="@Url.Action("ProductManagement", "Admin")" class="px-6 py-2.5 rounded-lg border border-gray-300 text-gray-700 font-medium hover:bg-gray-50 transition-colors">
                        Hủy
                    </a>
                    <button type="submit" class="px-6 py-2.5 rounded-lg bg-primary text-white font-medium hover:bg-primary-container shadow transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">save</span> Lưu thay đổi
                    </button>
                </div>
            }
        </div>
    </div>
</div>


    <script>document.getElementById('ImageUpload').addEventListener('change', function (event) {
            const file = event.target.files[0];
            const imgPreview = document.getElementById('img-preview');

            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    imgPreview.src = e.target.result; // Thay src của thẻ img bằng ảnh vừa up
                }
                reader.readAsDataURL(file);
            }
        });</script>


