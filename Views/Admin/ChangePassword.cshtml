@model PTDA_Demo.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "ChangePassword";
    Layout = "~/Views/Shared/_GreenMart_Dashboard_layout.cshtml";
}

<div class="max-w-xl mx-auto mt-10 bg-white p-8 rounded-lg shadow-md border border-gray-200">
    <h2 class="text-2xl font-bold text-gray-800 mb-6 border-b pb-2">Thay đổi mật khẩu</h2>

    @using (Html.BeginForm("ChangePassword", "Admin", FormMethod.Post, new { @class = "space-y-6" }))
    {
        @Html.AntiForgeryToken()

        <!-- Mật khẩu hiện tại -->
        <div>
            <label class="block text-gray-700 font-semibold mb-2">Mật khẩu hiện tại <span class="text-red-500">*</span></label>
            @Html.PasswordFor(m => m.CurrentPassword, new { @class = "w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-primary" })
            @Html.ValidationMessageFor(m => m.CurrentPassword, "", new { @class = "text-red-500 text-sm italic mt-1 block" })
        </div>

        <!-- Mật khẩu mới -->
        <div>
            <label class="block text-gray-700 font-semibold mb-2">Mật khẩu mới <span class="text-red-500">*</span></label>
            @Html.PasswordFor(m => m.NewPassword, new { @class = "w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-primary" })
            @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-red-500 text-sm italic mt-1 block" })
        </div>

        <!-- Xác nhận mật khẩu mới -->
        <div>
            <label class="block text-gray-700 font-semibold mb-2">Xác nhận mật khẩu mới <span class="text-red-500">*</span></label>
            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "w-full border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-primary" })
            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-red-500 text-sm italic mt-1 block" })
        </div>

        <!-- Nút Submit -->
        <div class="pt-4 flex justify-end">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-lg transition-colors">
                Cập nhật
            </button>
        </div>
    }
</div>

