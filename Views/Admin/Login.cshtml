@{
    Layout = null; // Giao diện này đã có sẵn toàn bộ cấu trúc HTML
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Login | GreenMart Management System</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-tertiary": "#ffffff",
                        "surface": "#fbf9f9",
                        "surface-bright": "#fbf9f9",
                        "secondary-fixed-dim": "#90d792",
                        "on-secondary": "#ffffff",
                        "error-container": "#ffdad6",
                        "on-primary-container": "#cbffc2",
                        "on-secondary-fixed": "#002107",
                        "on-error": "#ffffff",
                        "surface-dim": "#dbdad9",
                        "primary-container": "#2e7d32",
                        "outline": "#707a6c",
                        "outline-variant": "#bfcaba",
                        "inverse-primary": "#88d982",
                        "surface-variant": "#e3e2e2",
                        "on-tertiary-container": "#daf9db",
                        "tertiary-container": "#59745c",
                        "on-primary-fixed": "#002204",
                        "error": "#ba1a1a",
                        "inverse-on-surface": "#f2f0f0",
                        "on-tertiary-fixed": "#07200e",
                        "surface-container": "#efeded",
                        "surface-container-low": "#f5f3f3",
                        "on-surface": "#1b1c1c",
                        "on-secondary-container": "#2e7238",
                        "surface-container-highest": "#e3e2e2",
                        "primary-fixed": "#a3f69c",
                        "inverse-surface": "#303031",
                        "on-primary": "#ffffff",
                        "on-background": "#1b1c1c",
                        "on-surface-variant": "#40493d",
                        "surface-container-high": "#e9e8e7",
                        "on-primary-fixed-variant": "#005312",
                        "on-secondary-fixed-variant": "#07521d",
                        "surface-tint": "#1b6d24",
                        "on-tertiary-fixed-variant": "#334d37",
                        "primary": "#0d631b",
                        "surface-container-lowest": "#ffffff",
                        "background": "#fbf9f9",
                        "secondary-container": "#abf4ac",
                        "primary-fixed-dim": "#88d982",
                        "tertiary-fixed": "#cceacd",
                        "secondary": "#286b33",
                        "tertiary-fixed-dim": "#b1ceb2",
                        "tertiary": "#415b45",
                        "secondary-fixed": "#abf4ac",
                        "on-error-container": "#93000a"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "xs": "4px",
                        "lg": "40px",
                        "sm": "12px",
                        "margin-desktop": "48px",
                        "md": "24px",
                        "xl": "64px",
                        "margin-mobile": "16px",
                        "gutter": "24px",
                        "base": "8px",
                        "max-width": "1280px"
                    },
                    "fontFamily": {
                        "headline-md": ["Inter"],
                        "label-lg": ["Inter"],
                        "body-md": ["Inter"],
                        "label-sm": ["Inter"],
                        "body-lg": ["Inter"],
                        "body-sm": ["Inter"],
                        "headline-lg-mobile": ["Inter"],
                        "headline-lg": ["Inter"],
                        "display-lg": ["Inter"]
                    },
                    "fontSize": {
                        "headline-md": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                        "label-lg": ["14px", { "lineHeight": "20px", "letterSpacing": "0.01em", "fontWeight": "600" }],
                        "body-md": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "label-sm": ["12px", { "lineHeight": "16px", "letterSpacing": "0.04em", "fontWeight": "500" }],
                        "body-lg": ["18px", { "lineHeight": "28px", "fontWeight": "400" }],
                        "body-sm": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "headline-lg-mobile": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                        "headline-lg": ["32px", { "lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                        "display-lg": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700" }]
                    }
                },
            },
        }
    </script>

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-surface text-on-surface min-h-screen flex flex-col lg:flex-row">
    <div class="hidden lg:block lg:w-1/2 relative bg-surface-container-high overflow-hidden">
        <img class="absolute inset-0 w-full h-full object-cover" data-alt="..." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCEUJXRzHZvS4VoajGQrs4JGS3Ee7eyKW7m6edTjeAOowXXoBohrreRKlU6krUP1WO3TARN7-KTlNgBEaPT0nK43f5rrO3QBKxaxC4_2H_Y3izVzHuwCupP8i00zTPW56FhnwtizPn1olmdBsyBvoJQddomhRkfrtfiufM_T9eDAY50hoATIQZKwVldGmfl_Rs9LAJOzSNqbWcCCJiz-Z9cujEW6xEfnKvVtvu-KAy5nMxJ0gXweCMbLMp336Hc_3GERsuEvCw3OOE" />
        <div class="absolute inset-0 bg-primary/20 mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-surface-dim/80 via-transparent to-transparent"></div>
    </div>

    <div class="w-full lg:w-1/2 flex flex-col flex-grow min-h-screen bg-surface">
        <header class="flex justify-between items-center w-full px-md lg:px-xl py-6">
            <div class="flex items-center gap-base">
                <span class="material-symbols-outlined text-primary text-[28px]" style="font-variation-settings: 'FILL' 1;">eco</span>
                <span class="text-headline-md font-headline-md font-bold text-primary dark:text-primary-fixed">GreenMart</span>
            </div>
        </header>

        <main class="flex-grow flex items-center justify-center px-margin-mobile md:px-xl">
            <div class="w-full max-w-[480px]">
                <div class="mb-xl">
                    <h1 class="text-display-lg font-display-lg text-on-surface mb-sm">Welcome Back</h1>
                    <p class="text-body-lg font-body-lg text-on-surface-variant">Sign in to manage your inventory and sales.</p>
                </div>

                <div class="bg-surface-container-lowest rounded-2xl shadow-[0px_8px_30px_rgba(0,0,0,0.06)] border border-outline-variant/20 p-8 sm:p-10">

                    @* Khối hiển thị thông báo lỗi từ Controller *@
                    @if (ViewBag.Error != null)
                    {
                        <div class="mb-4 p-3 bg-error-container text-on-error-container border border-error rounded-lg font-body-md">
                            @ViewBag.Error
                        </div>
                    }
                    <!-- BỔ SUNG: Hiện thông báo hết hạn Session (TempData từ kịch bản 5) -->
                    @if (TempData["WarningMessage"] != null)
                    {
                        <div class="bg-tertiary-container/20 border border-tertiary text-on-surface-variant p-3 rounded-md mb-4 text-sm flex items-center gap-2">
                            <span class="material-symbols-outlined text-tertiary">info</span>
                            @TempData["WarningMessage"]
                        </div>
                    }
                    @* Cập nhật Form Action gửi POST về Account/Login *@
                    <form action="@Url.Action("Login", "Admin")" method="post" class="space-y-xl">
                        <div class="space-y-lg">
                            <div class="space-y-base">
                                <label class="text-label-lg font-label-lg text-on-surface" for="Email">Email/Username</label>
                                <div class="relative group">
                                    <span class="absolute left-sm top-1/2 -translate-y-1/2 material-symbols-outlined text-outline group-focus-within:text-primary transition-colors">person</span>

                                    @* Bổ sung name="Email", type="email", required và thông báo lỗi tùy chỉnh cho Scenario 5, 6 *@
                                    <input class="w-full pl-xl pr-md py-4 bg-surface-container-lowest border border-outline-variant rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-body-md font-body-md outline-none"
                                           id="Email" name="Email" type="email"
                                           required
                                           oninvalid="if(this.value === ''){this.setCustomValidity('Vui lòng nhập Email.')} else {this.setCustomValidity('Email không đúng định dạng.')}"
                                           oninput="this.setCustomValidity('')"
                                           placeholder="manager@greenmart.com" />
                                </div>
                            </div>

                            <div class="space-y-base">
                                <div class="flex justify-between items-center">
                                    <label class="text-label-lg font-label-lg text-on-surface" for="Password">Password</label>
                                    <a class="text-label-sm font-label-sm text-primary hover:text-primary-container transition-colors hover:underline" href="#">Forgot password?</a>
                                </div>
                                <div class="relative group">
                                    <span class="absolute left-sm top-1/2 -translate-y-1/2 material-symbols-outlined text-outline group-focus-within:text-primary transition-colors">lock</span>

                                    @* Bổ sung name="Password", required cho Scenario 5 *@
                                    <input class="w-full pl-xl pr-md py-4 bg-surface-container-lowest border border-outline-variant rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-body-md font-body-md outline-none"
                                           id="Password" name="Password" type="password"
                                           required
                                           oninvalid="this.setCustomValidity('Vui lòng nhập Mật khẩu.')"
                                           oninput="this.setCustomValidity('')"
                                           placeholder="••••••••" />
                                    @* <button class="absolute right-sm top-1/2 -translate-y-1/2 material-symbols-outlined text-outline hover:text-on-surface-variant transition-colors" type="button">visibility</button>*@
                                </div>
                            </div>
                        </div>

                        <button class="w-full bg-primary text-on-primary hover:bg-primary-container shadow-md hover:shadow-lg py-4 rounded-xl font-label-lg text-label-lg flex items-center justify-center gap-base active:scale-[0.98] transition-all duration-200" type="submit">
                            Sign In
                            <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                        </button>
                    </form>
                </div>
            </div>
        </main>
    </div>
</body>
</html>