@model PTDA_Demo.Models.EditAccountViewModel
@{
    ViewBag.Title = "EditAccount";
    Layout = "~/Views/Shared/_GreenMart_Dashboard_layout.cshtml";
    // Biến kiểm tra xem user đang sửa có phải chính là người đang đăng nhập không
    bool isCurrentUser = (Convert.ToInt32(Session["UserID"]) == Model.UserID);
}

@if (TempData["WarningMessage"] != null)
{
    <div class="bg-tertiary-container/20 border border-tertiary text-on-surface-variant p-3 rounded-md mb-4 text-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-tertiary">info</span>
        @TempData["WarningMessage"]
    </div>
}


<div class="max-w-5xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <div class="lg:col-span-2 bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
            <div class="bg-surface-container-high px-6 py-5 border-b border-gray-200 flex items-center gap-3">
                <span class="material-symbols-outlined text-primary text-[28px]">manage_accounts</span>
                <h2 class="text-xl font-bold text-gray-800">Chỉnh sửa thông tin</h2>
            </div>

            <div class="p-6">
                @using (Html.BeginForm("EditAccount", "Admin", FormMethod.Post, new { @class = "space-y-6" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.UserID)
                    @Html.HiddenFor(m => m.IsActive)

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Họ và tên <span class="text-red-500">*</span></label>
                    @*@Html.TextBoxFor(m => m.FullName, new { @class = "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none" })*@
                    @Html.DisplayFor(m => m.FullName, new { @class = "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none" })
                    @*@Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-red-500 text-xs italic mt-1 block" })*@
                </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
                            @*@Html.TextBoxFor(m => m.Email, new { type = "email", @class = "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none" })*@
                            @Html.DisplayFor(m => m.Email, new { type = "email", @class = "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none" })
                            @*@Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-red-500 text-xs italic mt-1 block" })*@
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Số điện thoại <span class="text-red-500">*</span></label>
                            @*@Html.TextBoxFor(m => m.PhoneNumber, new { @class = "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none" })*@
                            @Html.DisplayFor(m => m.PhoneNumber, new { @class = "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none" })
                            @*@Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "text-red-500 text-xs italic mt-1 block" })*@
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Vai trò phân quyền <span class="text-red-500">*</span></label>
                        @Html.DropDownListFor(m => m.RoleID, (SelectList)ViewBag.RoleList, new { @class = "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none bg-white" })
                        @Html.ValidationMessageFor(m => m.RoleID, "", new { @class = "text-red-500 text-xs italic mt-1 block" })
                    </div>

                    <div class="flex justify-end pt-4 border-t border-gray-100">
                        <button type="submit" class="px-6 py-2.5 rounded-lg bg-primary text-white font-medium hover:bg-primary-container shadow transition-all flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">save</span> Lưu thay đổi
                        </button>
                    </div>
                }
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden h-fit">
            <div class="bg-surface-container-high px-6 py-5 border-b border-gray-200">
                <h2 class="text-lg font-bold text-gray-800">Trạng thái hoạt động</h2>
            </div>

            <div class="p-6 text-center space-y-4">
                @if (Model.IsActive)
                {
                    <div class="mx-auto flex items-center justify-center w-16 h-16 bg-green-100 text-green-600 rounded-full mb-4">
                        <span class="material-symbols-outlined text-3xl">verified_user</span>
                    </div>
                    <h3 class="text-lg font-bold text-green-700">Đang hoạt động</h3>
                    <p class="text-sm text-gray-500">Tài khoản này có thể truy cập hệ thống bình thường.</p>
                }
                else
                {
                    <div class="mx-auto flex items-center justify-center w-16 h-16 bg-red-100 text-red-600 rounded-full mb-4">
                        <span class="material-symbols-outlined text-3xl">block</span>
                    </div>
                    <h3 class="text-lg font-bold text-red-700">Đã bị khóa</h3>
                    <p class="text-sm text-gray-500">Tài khoản này không thể đăng nhập vào hệ thống.</p>
                }

                <hr class="border-gray-200" />

                @using (Html.BeginForm("ToggleAccountStatus", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="targetUserId" value="@Model.UserID" />

                    if (isCurrentUser)
                    {
                        <button type="button" disabled class="w-full px-4 py-2 mt-2 rounded-lg bg-gray-300 text-gray-500 font-medium cursor-not-allowed flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">lock</span>
                            Không thể khóa tài khoản của bạn
                        </button>
                    }
                    else if (Model.IsActive)
                    {
                        <button type="submit" onclick="return confirm('Bạn có chắc chắn muốn KHÓA tài khoản này không?');" class="w-full px-4 py-2 mt-2 rounded-lg bg-red-600 hover:bg-red-700 text-white font-medium shadow transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">lock</span>
                            Khóa tài khoản
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="w-full px-4 py-2 mt-2 rounded-lg bg-green-600 hover:bg-green-700 text-white font-medium shadow transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-sm">lock_open</span>
                            Mở khóa tài khoản
                        </button>
                    }
                }
            </div>
        </div>

    </div>
</div>

