@model PTDA_Demo.Models.CreateAccountViewModel
@{
    ViewBag.Title = "CreateAccount";
    Layout = "~/Views/Shared/_GreenMart_Dashboard_layout.cshtml";
}


<div class="max-w-4xl mx-auto px-4 py-8">
    <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">

        <div class="bg-surface-container-high px-6 py-5 border-b border-gray-200 flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-[28px]">person_add</span>
            <h2 class="text-xl font-bold text-gray-800">Tạo tài khoản nội bộ mới</h2>
        </div>

        <div class="p-6 sm:p-8">
            @using (Html.BeginForm("CreateAccount", "Admin", FormMethod.Post, new { @class = "space-y-6" }))
            {
                @Html.AntiForgeryToken()

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">
                        Họ và tên <span class="text-red-500">*</span>
                    </label>
                    @Html.TextBoxFor(m => m.FullName, new { @class = "w-full border border-gray-300 rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-colors text-sm", placeholder = "Ví dụ: Nguyễn Văn A" })
                    @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-red-500 text-xs italic mt-1 block" })
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">
                            Email <span class="text-red-500">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.Email, new { type = "email", @class = "w-full border border-gray-300 rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-colors text-sm", placeholder = "nhanvien@greenmart.vn" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-red-500 text-xs italic mt-1 block" })
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">
                            Số điện thoại <span class="text-red-500">*</span>
                        </label>
                        @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "w-full border border-gray-300 rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-colors text-sm", placeholder = "0987xxxxxx" })
                        @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "text-red-500 text-xs italic mt-1 block" })
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">
                            Mật khẩu khởi tạo <span class="text-red-500">*</span>
                        </label>
                        @Html.PasswordFor(m => m.Password, new { @class = "w-full border border-gray-300 rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-colors text-sm", placeholder = "Ít nhất 6 ký tự gồm chữ & số" })
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-red-500 text-xs italic mt-1 block" })
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">
                            Vai trò <span class="text-red-500">*</span>
                        </label>
                        @Html.DropDownListFor(m => m.RoleID, (SelectList)ViewBag.RoleList, "-- Chọn vai trò --", new { @class = "w-full border border-gray-300 rounded-lg p-3 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition-colors text-sm bg-white" })
                        @Html.ValidationMessageFor(m => m.RoleID, "", new { @class = "text-red-500 text-xs italic mt-1 block" })
                    </div>
                </div>

                <div class="flex items-center justify-end gap-4 pt-6 border-t border-gray-100 mt-8">
                    <a href="@Url.Action("AccountManagement", "Admin")" class="px-6 py-2.5 rounded-lg border border-gray-300 text-gray-700 font-medium hover:bg-gray-50 transition-colors">
                        Hủy
                    </a>

                    <button type="submit" class="px-6 py-2.5 rounded-lg bg-primary text-white font-medium hover:bg-primary-container shadow hover:shadow-md transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">save</span>
                        Tạo mới
                    </button>
                </div>
            }
        </div>
    </div>
</div>

